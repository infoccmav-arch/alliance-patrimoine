# 1. Créer un compte gratuit sur https://supabase.com
# 2. Créer un nouveau projet (choisir Canada East comme région)
# 3. Aller dans Settings → API
# 4. Copier "Project URL" et "anon public key" ci-dessous
# 5. Renommer ce fichier en .env.local (supprimer le .example)

VITE_SUPABASE_URL=https://VOTRE-ID-PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=votre-anon-key-ici
